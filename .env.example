# APP_DEBUG=true
# APP_URL=http://127.0.0.1:8000

APP_LOCALE=hy
APP_FALLBACK_LOCALE=hy
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gpemureqjaea_vertoni
DB_USERNAME=verthoni_admin
DB_PASSWORD=4;iMu%J;oMVB_Jk)

# Local sqlite option:
# DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.verthoni.com
# Local option:
# SESSION_DOMAIN=null

SANCTUM_STATEFUL_DOMAINS=verthoni.com,www.verthoni.com,localhost:3000,127.0.0.1:3000
CORS_ALLOWED_ORIGINS=https://verthoni.com,https://www.verthoni.com,http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=https://verthoni.com
# Local option:
# FRONTEND_URL=http://localhost:3000

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=mail.verthoni.com
MAIL_PORT=465
MAIL_USERNAME=info@verthoni.com
MAIL_PASSWORD=Edgaredgar123
MAIL_FROM_ADDRESS=info@verthoni.com
