APP_NAME=Verthoni
APP_ENV=production
APP_DEBUG=false
APP_URL=https://verthoni.com
APP_LOCALE=hy
APP_FALLBACK_LOCALE=hy
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=verthoni
DB_USERNAME=verthoni_user
DB_PASSWORD=
SESSION_DRIVER=database
SESSION_DOMAIN=.verthoni.com
SANCTUM_STATEFUL_DOMAINS=verthoni.com,www.verthoni.com
CORS_ALLOWED_ORIGINS=https://verthoni.com,https://www.verthoni.com
FRONTEND_URL=https://verthoni.com
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
MAIL_FROM_ADDRESS=info@verthoni.com
MAIL_FROM_NAME="${APP_NAME}"

# UPLOAD_LIMIT_NOTE:
# Admin video uploads use Livewire temporary uploads.
# Code limit is 200MB in config/livewire.php and Filament FileUpload fields.
# Local XAMPP php.ini must also allow it:
# upload_max_filesize=200M
# post_max_size=220M
# max_execution_time=300
# memory_limit=512M
