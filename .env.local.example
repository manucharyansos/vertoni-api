APP_NAME=Verthoni
APP_ENV=local
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_LOCALE=hy
APP_FALLBACK_LOCALE=hy
DB_CONNECTION=sqlite
DB_DATABASE=/absolute/path/to/database/database.sqlite
SESSION_DRIVER=database
SESSION_DOMAIN=null
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
MAIL_MAILER=log
MAIL_FROM_ADDRESS=info@verthoni.com
MAIL_FROM_NAME="${APP_NAME}"

# UPLOAD_LIMIT_NOTE:
# Admin video uploads use Livewire temporary uploads.
# Code limit is 200MB in config/livewire.php and Filament FileUpload fields.
# Local XAMPP php.ini must also allow it:
# upload_max_filesize=200M
# post_max_size=220M
# max_execution_time=300
# memory_limit=512M
